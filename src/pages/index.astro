---
import { url } from '../utils';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, TAGLINE, CONTACT_EMAIL } from '../consts';
---

<BaseLayout
  title={undefined}
  description={SITE_DESCRIPTION}
  isHome={true}
>

<!-- Marca de motion: se ejecuta antes de pintar el hero para evitar destellos.
     Si el usuario prefiere menos movimiento, no se oculta nada. -->
<script is:inline>
  try {
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('motion-ready');
    }
  } catch (e) {}
</script>

<!-- ================================================================ -->
<!-- Hero Section                                                       -->
<!-- ================================================================ -->
<section class="hero" style={`background-image: url('${url('/images/hero/hero-background.jpg')}')`}>
  <div class="hero__fx" aria-hidden="true">
    <span class="hero__orb hero__orb--one"></span>
    <span class="hero__orb hero__orb--two"></span>
    <span class="hero__orb hero__orb--three"></span>
    <span class="hero__grid"></span>
  </div>
  <div class="container hero__inner">
    <span class="hero__badge">Estrategia de IA para medianas empresas</span>
    <h1 class="hero__title">
      Tu empresa necesita un sistema operativo de IA
    </h1>
    <p class="hero__subtitle">
      Ayudo a medianas empresas españolas a pasar de pilotos sueltos y herramientas dispersas a un sistema: estrategia, gobierno, datos, procesos y personas preparadas para la era de la IA. Sin humo: quien diseña la estrategia es quien la ejecuta contigo.
    </p>
    <div class="hero__actions">
      <a href="#contacto" class="btn btn--primary btn--lg">Reserva una conversación estratégica</a>
      <a href={url('/servicios/sistema-operativo-ia/')} class="btn btn--outline btn--lg">Qué es el sistema operativo de IA</a>
    </div>
    <p class="hero__actions-note">
      ¿Tienes una pyme o un despacho profesional? La <a href={url('/para-pymes/')}>línea para pymes</a> sigue aquí: automatización concreta con precio cerrado para <a href={url('/ia-para-asesorias/')}>asesorías</a>, <a href={url('/ia-para-abogados/')}>abogados</a> y <a href={url('/casos/')}>otros sectores</a>.
    </p>
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-number" data-count="30">30</span>
        <span class="hero__stat-unit">min</span>
        <span class="hero__stat-label">de conversación inicial, gratis y sin compromiso</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-number" data-count="90">90</span>
        <span class="hero__stat-unit">días</span>
        <span class="hero__stat-label">el horizonte de cada fase: nada de transformaciones eternas</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-number">1</span>
        <span class="hero__stat-unit"></span>
        <span class="hero__stat-label">interlocutor: quien diseña tu estrategia responde por ella</span>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Problem Statement                                                  -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header reveal">
      <h2 class="section__title">A tu empresa no le falta IA. Le falta sistema.</h2>
      <p class="section__subtitle">
        Seguramente ya hay IA en tu empresa: gente usando ChatGPT por su cuenta, algún piloto que no despega, herramientas contratadas que nadie gobierna y presión por "hacer algo" antes que la competencia. El problema no es la falta de herramientas: es que no hay estrategia, ni criterio, ni responsables. Eso —el sistema operativo de IA de tu empresa— es lo que diseño contigo.
      </p>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- El sistema operativo de IA — las cuatro capas                      -->
<!-- ================================================================ -->
<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Qué es un sistema operativo de IA</h2>
      <p class="section__subtitle">
        No es una herramienta que se compra: es el conjunto de decisiones, reglas y capacidades que hace que la IA funcione en toda la empresa, no solo en demos. Cuatro capas, y las cuatro tienen que estar.
      </p>
    </div>

    <div class="grid grid--4 reveal-stagger">
      <div class="card reveal">
        <h3 class="card__title">Estrategia y gobierno</h3>
        <p class="card__desc">Dónde aporta la IA en tu negocio, con qué prioridades y con qué límites. Política de uso, responsables y criterios de inversión: la alternativa al "cada uno usa lo que quiere".</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">Datos y conocimiento</h3>
        <p class="card__desc">Qué información tiene la empresa, en qué estado está y qué hace falta para que la IA trabaje con ella de forma segura y útil.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">Procesos y automatización</h3>
        <p class="card__desc">Llevar la IA a los flujos reales de cada departamento —operaciones, administración, comercial, atención al cliente— con resultados que se miden.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">Personas y adopción</h3>
        <p class="card__desc">Formación por rol, nuevos hábitos de trabajo y una dirección alineada. La capa que decide si todo lo demás se usa o se abandona.</p>
      </div>
    </div>

    <div class="pb-pullquote" style="margin-top: 3rem; text-align: center;">
      Ninguna empresa seria funciona sin sistema de gestión. Ninguna va a funcionar bien en la era de la IA sin su sistema operativo de IA.
    </div>

    <div style="text-align: center; margin-top: 2rem;">
      <a href={url('/servicios/sistema-operativo-ia/')} class="btn btn--primary">Cómo diseño tu AI OS</a>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Service Pillars                                                    -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Tres servicios, una escalera</h2>
      <p class="section__subtitle">
        Empieza por el primer escalón y decide después. Cada fase se cierra por escrito —alcance, plazo e importe— antes de empezar. Nunca por horas, nunca proyectos eternos.
      </p>
    </div>

    <div class="grid grid--3 reveal-stagger">
      <!-- Pilar 1: Diagnóstico de madurez -->
      <a href={url('/servicios/diagnostico-madurez-ia/')} class="card card--link reveal">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </div>
        <h3 class="card__title">1. Diagnóstico de madurez en IA</h3>
        <p class="card__desc">
          Una radiografía honesta de dónde está tu empresa: estrategia, datos, procesos, personas y gobierno. Con oportunidades priorizadas y un plan de primeros 90 días.
        </p>
        <span class="card__link">Saber más</span>
      </a>

      <!-- Pilar 2: Diseño del AI OS -->
      <a href={url('/servicios/sistema-operativo-ia/')} class="card card--link reveal">
        <div class="card__icon card__icon--accent">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>
          </svg>
        </div>
        <h3 class="card__title">2. Diseño de tu sistema operativo de IA</h3>
        <p class="card__desc">
          El servicio central: estrategia, gobierno, arquitectura de herramientas y datos, y una hoja de ruta por trimestres que dirección puede aprobar y auditar.
        </p>
        <span class="card__link">Saber más</span>
      </a>

      <!-- Pilar 3: Acompañamiento estratégico -->
      <a href={url('/servicios/acompanamiento-estrategico/')} class="card card--link reveal">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="card__title">3. Acompañamiento estratégico</h3>
        <p class="card__desc">
          Dirección de IA externa, mes a mes: ejecutar la hoja de ruta con tu equipo, medir la adopción y decidir con criterio. Sin permanencia.
        </p>
        <span class="card__link">Saber más</span>
      </a>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- How I Work                                                         -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Cómo trabajo</h2>
      <p class="section__subtitle">
        Un proceso simple, pensado para que en cada paso sepas qué recibes y cuánto cuesta.
      </p>
    </div>

    <div class="grid grid--4 reveal-stagger">
      <div class="card reveal">
        <h3 class="card__title">1. Hablamos</h3>
        <p class="card__desc">Conversación de 30 minutos, gratis. Me cuentas dónde está tu empresa con la IA y te digo con honestidad si puedo aportarte o no.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">2. Diagnóstico</h3>
        <p class="card__desc">Mido la madurez de tu empresa en las cuatro capas del sistema operativo de IA y priorizo las oportunidades por impacto y esfuerzo.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">3. Diseño del AI OS</h3>
        <p class="card__desc">Diseño con dirección la estrategia, el gobierno y la hoja de ruta por trimestres. Alcance, plazo e importe cerrados por escrito.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">4. Ejecución</h3>
        <p class="card__desc">Acompaño a tu equipo mes a mes para que la hoja de ruta avance: dirección, formación por rol y medición. Sin permanencia.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Mid CTA — Diagnóstico gratuito                                     -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="cta cta--inline reveal" aria-label="Reserva una conversación estratégica">
      <div class="cta__inner">
        <h2 class="cta__title">Empieza con 30 minutos, gratis</h2>
        <p class="cta__desc">
          Una conversación sin compromiso en la que repasamos dónde está tu empresa con la IA y te llevas valor desde el primer día, contrates o no.
        </p>
        <ul class="cta__benefits">
          <li>Una foto rápida de tu madurez en IA: qué tenéis, qué falta</li>
          <li>Los 2-3 movimientos con más impacto en tu caso</li>
          <li>Una opinión honesta: si no puedo aportarte, te lo digo</li>
        </ul>
        <a href="#contacto" class="btn btn--outline-white btn--lg">Reservar mi conversación</a>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Línea secundaria — pymes y despachos profesionales                 -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">¿Tienes una pyme o un despacho profesional?</h2>
      <p class="section__subtitle">
        La línea con la que nació Eraldia sigue activa: automatización concreta con IA, precio cerrado y proyectos de semanas para asesorías, gestorías, despachos de abogados y otras pymes.
      </p>
    </div>

    <div class="grid grid--3 reveal-stagger">
      <a href={url('/ia-para-asesorias/')} class="card card--link reveal">
        <h3 class="card__title">Asesorías y gestorías</h3>
        <p class="card__desc">Picado de facturas, plazos, consultas repetidas y onboarding. Llega a la campaña de renta con margen.</p>
        <span class="card__link">Ver automatizaciones y precios</span>
      </a>
      <a href={url('/ia-para-abogados/')} class="card card--link reveal">
        <h3 class="card__title">Despachos de abogados</h3>
        <p class="card__desc">Expedientes, plazos procesales e intake de clientes, siempre con el secreto profesional por delante.</p>
        <span class="card__link">Ver automatizaciones y precios</span>
      </a>
      <a href={url('/para-pymes/')} class="card card--link reveal">
        <h3 class="card__title">Otras pymes</h3>
        <p class="card__desc">Clínicas, gimnasios, inmobiliarias, climatización… Si hay un proceso manual que duele, hay proyecto.</p>
        <span class="card__link">Ver la línea para pymes</span>
      </a>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Contact form — lead capture                                        -->
<!-- ================================================================ -->
<section class="section section--alt" id="contacto">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Cuéntame dónde está tu empresa</h2>
      <p class="section__subtitle">
        Escríbeme dos líneas sobre tu empresa y qué te preocupa de la IA, y te respondo en menos de 24 horas laborables con los siguientes pasos. Sin spam y sin listas de correo.
      </p>
    </div>

    <form class="contact-form reveal" id="contact-form" action={url('/api/lead/')} method="POST" data-email={CONTACT_EMAIL}>
      <input type="hidden" name="source" value="contacto">
      <div class="contact-form__row">
        <div class="contact-form__field">
          <label for="cf-nombre" class="contact-form__label">Nombre</label>
          <input type="text" id="cf-nombre" name="nombre" class="contact-form__input" required autocomplete="name">
        </div>
        <div class="contact-form__field">
          <label for="cf-email" class="contact-form__label">Email</label>
          <input type="email" id="cf-email" name="email" class="contact-form__input" required autocomplete="email">
        </div>
      </div>
      <div class="contact-form__field">
        <label for="cf-negocio" class="contact-form__label">¿A qué se dedica tu empresa?</label>
        <input type="text" id="cf-negocio" name="negocio" class="contact-form__input" placeholder="Ej.: industria, distribución, servicios... y cuántas personas sois">
      </div>
      <div class="contact-form__field">
        <label for="cf-mensaje" class="contact-form__label">¿Dónde estáis con la IA y qué te preocupa?</label>
        <textarea id="cf-mensaje" name="mensaje" class="contact-form__textarea" rows="4" required placeholder="Ej.: cada departamento usa ChatGPT por su cuenta, tenemos pilotos que no despegan, dirección pide un plan..."></textarea>
      </div>
      {/* Honeypot anti-spam */}
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">
      <button type="submit" class="btn btn--primary btn--lg contact-form__submit">Enviar y reservar mi llamada gratuita</button>
      <p class="contact-form__note">Al enviar aceptas que use estos datos solo para responderte. Nada de newsletters sorpresa.</p>
      <p class="contact-form__feedback" id="contact-feedback" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>

<script is:inline>
(function () {
  var form = document.getElementById('contact-form');
  if (!form) return;
  var feedback = document.getElementById('contact-feedback');
  var btn = form.querySelector('button[type="submit"]');

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando…'; }
    if (feedback) { feedback.hidden = true; feedback.className = 'contact-form__feedback'; }

    fetch(form.action, {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: new FormData(form)
    })
      .then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
      .then(function (data) {
        if (data && data.ok) {
          form.reset();
          if (feedback) {
            feedback.textContent = '¡Recibido! Te respondo en menos de 24 horas laborables.';
            feedback.classList.add('is-success');
            feedback.hidden = false;
          }
          if (btn) btn.textContent = 'Enviado ✓';
        } else {
          throw new Error((data && data.error) || 'Error');
        }
      })
      .catch(function () {
        if (feedback) {
          feedback.textContent = 'No se pudo enviar. Inténtalo de nuevo o escríbeme a ' + (form.getAttribute('data-email') || '') + '.';
          feedback.classList.add('is-error');
          feedback.hidden = false;
        }
        if (btn) { btn.disabled = false; btn.textContent = 'Enviar y reservar mi llamada gratuita'; }
      });
  });
})();
</script>

<!-- ================================================================ -->
<!-- Motion (motion.dev): entrada del hero, contadores y parallax       -->
<!-- ================================================================ -->
<script>
  import { animate, stagger, inView } from 'motion';

  const easeOut = [0.16, 1, 0.3, 1];
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // 1) Contadores de las cifras del hero — se disparan al entrar en pantalla.
  //    Con reduced-motion se dejan tal cual (el HTML ya muestra el valor final).
  document.querySelectorAll('.hero__stat-number[data-count]').forEach((el) => {
    const to = parseFloat(el.dataset.count);
    const suffix = el.dataset.suffix || '';
    if (reduce || Number.isNaN(to)) return;
    el.textContent = '0' + suffix;
    inView(el, () => {
      animate(0, to, {
        duration: 1.4,
        ease: easeOut,
        onUpdate: (v) => { el.textContent = Math.round(v) + suffix; },
      });
    }, { amount: 0.6 });
  });

  // El resto solo se ejecuta si marcamos motion-ready (JS activo, sin reduced-motion).
  if (document.documentElement.classList.contains('motion-ready')) {
    // 2) Título palabra a palabra.
    const title = document.querySelector('.hero__title');
    if (title) {
      const words = title.textContent.trim().split(/\s+/);
      title.textContent = '';
      words.forEach((w, i) => {
        const span = document.createElement('span');
        span.className = 'hero__word';
        span.textContent = w;
        title.appendChild(span);
        if (i < words.length - 1) title.appendChild(document.createTextNode(' '));
      });
      title.style.opacity = '1';
      animate(
        '.hero__word',
        { opacity: [0, 1], transform: ['translateY(28px)', 'translateY(0)'] },
        { duration: 0.7, ease: easeOut, delay: stagger(0.05, { startDelay: 0.15 }) },
      );
    }

    // La insignia solo se atenúa (su animación pulseBadge sigue con el scale).
    const badge = document.querySelector('.hero__badge');
    if (badge) {
      animate(badge, { opacity: [0, 1] }, { duration: 0.6, ease: easeOut, delay: 0.1 });
    }

    // 3) Entrada escalonada del resto del bloque.
    const seq = document.querySelectorAll(
      '.hero__subtitle, .hero__actions, .hero__actions-note, .hero__stat',
    );
    if (seq.length) {
      animate(
        seq,
        { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0)'] },
        { duration: 0.7, ease: easeOut, delay: stagger(0.08, { startDelay: 0.35 }) },
      );
    }

    // 4) Parallax suave de los orbes/rejilla al mover el puntero.
    const hero = document.querySelector('.hero');
    const fx = document.querySelector('.hero__fx');
    if (hero && fx && matchMedia('(pointer: fine)').matches) {
      hero.addEventListener('pointermove', (e) => {
        const r = hero.getBoundingClientRect();
        const dx = ((e.clientX - r.left) / r.width - 0.5) * 24;
        const dy = ((e.clientY - r.top) / r.height - 0.5) * 24;
        animate(fx, { x: dx, y: dy }, { duration: 0.9, ease: 'easeOut' });
      });
      hero.addEventListener('pointerleave', () => {
        animate(fx, { x: 0, y: 0 }, { duration: 1.2, ease: 'easeOut' });
      });
    }
  }
</script>

</BaseLayout>
